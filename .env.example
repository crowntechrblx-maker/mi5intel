SESSION_SECRET=change_this_to_a_long_random_string_minimum_32_chars
SETUP_TOKEN=your_one_time_setup_token_to_create_first_admin
PORT=3000

# PostgreSQL connection string (Neon, Render, Supabase, etc.)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Your app's public URL (used for redirects)
APP_URL=https://your-app.onrender.com
