SESSION_SECRET=change_this_to_a_long_random_string_minimum_32_chars
SETUP_TOKEN=your_one_time_setup_token_to_create_first_admin
PORT=3000

# PostgreSQL connection string (Neon, Render, Supabase, etc.)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Your app's public URL (used for redirects and og:image embed links)
APP_URL=https://your-app.onrender.com
BASE_URL=https://your-app.onrender.com

# Roblox bot account cookie — enables fetching private group member lists.
# Log into a Roblox alt account in your browser, open DevTools → Application →
# Cookies → .ROBLOSECURITY, copy the value (the long string after the WARNING).
# Keep this secret — anyone with it can act as that Roblox account.
ROBLOX_COOKIE=

# IP allowlist — comma-separated. Only these IPs can access /admin, /audit, /settings.
# Leave unset to disable the restriction (all authenticated users can access).
# Find your IP at https://whatismyip.com
ALLOWED_IPS=1.2.3.4

# Session idle timeout in minutes (default: 60). After this long without activity the session is killed.
SESSION_TIMEOUT_MINUTES=60

# Discord shift log integration — create a bot at discord.com/developers, add it to
# your server with Read Messages permission, copy its token and the channel ID.
DISCORD_BOT_TOKEN=
DISCORD_SHIFT_CHANNEL_ID=
