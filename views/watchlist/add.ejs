<%- include('../partials/header', { pageTitle: 'Register Entity' }) %>

<div class="page-header">
  <div>
    <h1 class="page-title">REGISTER NEW ENTITY</h1>
    <p class="page-subtitle">Add a single Roblox user to the intelligence registry</p>
  </div>
  <a href="/watchlist/batch" class="btn btn-secondary">BATCH UPLOAD INSTEAD</a>
</div>

<div class="form-panel">
  <% if (error) { %>
  <div class="alert alert-error"><%= error %></div>
  <% } %>

  <form action="/watchlist/add" method="POST" class="intel-form">
    <div class="form-section">
      <h2 class="section-title">ROBLOX IDENTITY</h2>
      <div class="form-group">
        <label class="form-label" for="identifier">USERNAME OR USER ID <span class="required">*</span></label>
        <input class="form-input" type="text" id="identifier" name="identifier" placeholder="e.g. Builderman or 156" required autofocus>
        <span class="form-hint">Enter the Roblox username or numeric user ID. Data will be fetched live from the Roblox API.</span>
      </div>
    </div>

    <div class="form-section">
      <h2 class="section-title">CLASSIFICATION</h2>
      <div class="form-row">
        <div class="form-group">
          <label class="form-label" for="severity">SURVEILLANCE SEVERITY</label>
          <select class="form-input" id="severity" name="severity">
            <option value="LOW">LOW</option>
            <option value="MEDIUM">MEDIUM</option>
            <option value="HIGH">HIGH</option>
            <option value="CRITICAL">CRITICAL</option>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label" for="category">CLASSIFICATION CATEGORY</label>
          <input class="form-input" type="text" id="category" name="category" value="UNCATEGORISED" placeholder="e.g. FRAUD, HARASSMENT">
        </div>
      </div>
      <div class="form-group">
        <label class="form-label" for="tags">TAGS <span class="form-hint-inline">(comma separated)</span></label>
        <input class="form-input" type="text" id="tags" name="tags" placeholder="e.g. SCAMMER, ALT-ACCOUNT, GROOMER">
      </div>
    </div>

    <div class="form-section">
      <h2 class="section-title">INTELLIGENCE NOTES</h2>
      <div class="form-group">
        <label class="form-label" for="notes">ANALYST NOTES</label>
        <textarea class="form-input form-textarea" id="notes" name="notes" rows="4" placeholder="Enter any relevant intelligence notes, incident references, or context..."></textarea>
      </div>
    </div>

    <div class="form-actions">
      <button class="btn btn-primary" type="submit" id="submit-btn">
        <span class="btn-text">FETCH & REGISTER ENTITY</span>
        <span class="btn-loading" style="display:none">FETCHING FROM ROBLOX API...</span>
      </button>
      <a href="/watchlist" class="btn btn-ghost">CANCEL</a>
    </div>
  </form>
</div>

<script>
document.querySelector('.intel-form').addEventListener('submit', function() {
  document.querySelector('.btn-text').style.display = 'none';
  document.querySelector('.btn-loading').style.display = 'inline';
  document.querySelector('#submit-btn').disabled = true;
});
</script>

<%- include('../partials/footer') %>
