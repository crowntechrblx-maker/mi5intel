<%- include('../partials/header', { pageTitle: 'Watchlist' }) %>

<div class="govuk-page-header">
  <div>
    <span class="govuk-caption-m">INTELLIGENCE REGISTRY</span>
    <h1 class="govuk-heading-xl">Watchlist Database</h1>
  </div>
  <div class="govuk-page-header__actions">
    <a href="/watchlist/batch" class="govuk-button govuk-button--secondary">BATCH UPLOAD</a>
    <a href="/watchlist/add" class="govuk-button govuk-button--primary">+ REGISTER ENTITY</a>
  </div>
</div>

<div class="filter-bar">
  <form action="/watchlist" method="GET" class="filter-form">
    <div class="search-wrap">
      <svg class="search-icon" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd"/></svg>
      <input class="search-input" type="text" name="q" value="<%= filters.q || '' %>" placeholder="Search by username, category, Roblox ID…">
    </div>
    <select name="severity" class="filter-select">
      <option value="">ALL SEVERITIES</option>
      <option value="CRITICAL" <%= filters.severity === 'CRITICAL' ? 'selected' : '' %>>CRITICAL</option>
      <option value="HIGH"     <%= filters.severity === 'HIGH'     ? 'selected' : '' %>>HIGH</option>
      <option value="MEDIUM"   <%= filters.severity === 'MEDIUM'   ? 'selected' : '' %>>MEDIUM</option>
      <option value="LOW"      <%= filters.severity === 'LOW'      ? 'selected' : '' %>>LOW</option>
    </select>
    <select name="status" class="filter-select">
      <option value="">ALL STATUSES</option>
      <option value="ACTIVE"   <%= filters.status === 'ACTIVE'   ? 'selected' : '' %>>ACTIVE</option>
      <option value="INACTIVE" <%= filters.status === 'INACTIVE' ? 'selected' : '' %>>INACTIVE</option>
      <option value="ARCHIVED" <%= filters.status === 'ARCHIVED' ? 'selected' : '' %>>ARCHIVED</option>
      <option value="BANNED"   <%= filters.status === 'BANNED'   ? 'selected' : '' %>>BANNED</option>
    </select>
    <button type="submit" class="govuk-button govuk-button--secondary govuk-button--small">FILTER</button>
    <a href="/watchlist" class="govuk-button govuk-button--ghost govuk-button--small">CLEAR</a>
  </form>
</div>

<div class="govuk-table-wrapper">
  <table class="govuk-table">
    <thead class="govuk-table__head">
      <tr>
        <th class="govuk-table__header" style="width:60px">#</th>
        <th class="govuk-table__header">TARGET IDENTITY</th>
        <th class="govuk-table__header">CATEGORY</th>
        <th class="govuk-table__header">SEVERITY</th>
        <th class="govuk-table__header">STATUS</th>
        <th class="govuk-table__header" style="width:120px"></th>
      </tr>
    </thead>
    <tbody class="govuk-table__body">
      <% if (entities.length === 0) { %>
      <tr>
        <td colspan="6" class="govuk-table__cell govuk-table__cell--empty">
          NO ENTITY INDEXES DETECTED WITHIN QUERY PARAMETERS
        </td>
      </tr>
      <% } else { %>
      <% entities.forEach(function(e) { %>
      <tr class="govuk-table__row entity-tr" data-href="/watchlist/<%= e.id %>">
        <td class="govuk-table__cell">
          <span class="entity-index"><%= String(e.id).padStart(4, '0') %></span>
        </td>
        <td class="govuk-table__cell">
          <div class="identity-cell">
            <div class="table-avatar">
              <% if (e.avatar_url) { %>
                <img src="<%= e.avatar_url %>" alt="">
              <% } else { %>
                <span><%= e.username.charAt(0).toUpperCase() %></span>
              <% } %>
            </div>
            <div>
              <div class="table-username"><%= e.username %></div>
              <div class="table-meta">
                <%= e.display_name && e.display_name !== e.username ? e.display_name + ' &bull; ' : '' %>
                <%= e.roblox_id %>
              </div>
            </div>
          </div>
        </td>
        <td class="govuk-table__cell">
          <span class="category-tag"><%= e.category %></span>
          <% if (e.tags && e.tags.length > 0) { %>
            <% e.tags.slice(0, 2).forEach(function(tag) { %>
            <span class="mini-tag"><%= tag %></span>
            <% }); %>
          <% } %>
        </td>
        <td class="govuk-table__cell">
          <strong class="govuk-tag govuk-tag--sev-<%= e.severity.toLowerCase() %>"><%= e.severity %></strong>
        </td>
        <td class="govuk-table__cell">
          <strong class="govuk-tag govuk-tag--status-<%= e.status.toLowerCase() %>"><%= e.status %></strong>
        </td>
        <td class="govuk-table__cell">
          <a href="/watchlist/<%= e.id %>" class="table-action-btn">VIEW DOSSIER</a>
        </td>
      </tr>
      <% }); %>
      <% } %>
    </tbody>
  </table>
  <div class="table-footer">
    <span class="table-count"><%= entities.length %> ENTITY INDEX<%= entities.length !== 1 ? 'ES' : '' %> WITHIN CURRENT PARAMETERS</span>
  </div>
</div>

<%- include('../partials/footer') %>
