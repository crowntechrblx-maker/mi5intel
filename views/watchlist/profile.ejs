<%- include('../partials/header', { pageTitle: entity.username, page: 'watchlist' }) %>

<div class="page-header">
  <div>
    <h1 class="page-title">ENTITY DOSSIER — <%= entity.username.toUpperCase() %></h1>
    <p class="page-subtitle">Intelligence file #<%= String(entity.id).padStart(4, '0') %> &bull; Roblox ID: <%= entity.roblox_id %></p>
  </div>
  <div class="header-actions">
    <form action="/watchlist/<%= entity.id %>/refresh" method="POST" style="display:inline">
      <button class="btn btn-secondary" type="submit" id="refresh-btn" onclick="this.disabled=true;this.textContent='REFRESHING…'">REFRESH FROM API</button>
    </form>
    <a href="/watchlist" class="btn btn-ghost">← BACK TO REGISTRY</a>
  </div>
</div>

<% if (added) { %><div class="alert alert-success" style="margin-bottom:1rem">Entity successfully registered in the intelligence database.</div><% } %>
<% if (info === 'already_exists') { %><div class="alert alert-info" style="margin-bottom:1rem">This entity already exists in the registry.</div><% } %>

<% const p = entity.profile; %>

<div class="profile-grid">

  <!-- LEFT: Avatar & Core Info -->
  <div class="profile-left">
    <div class="panel">
      <div class="avatar-section">
        <% if (p && p.body_avatar_url) { %>
          <img class="profile-avatar" src="<%= p.body_avatar_url %>" alt="<%= entity.username %>">
        <% } else if (entity.avatar_url) { %>
          <img class="profile-avatar profile-avatar--head" src="<%= entity.avatar_url %>" alt="<%= entity.username %>">
        <% } else { %>
          <div class="profile-avatar-placeholder"><%= entity.username.charAt(0).toUpperCase() %></div>
        <% } %>
        <% if (p && p.is_banned) { %>
          <div class="banned-overlay">ACCOUNT BANNED</div>
        <% } %>
      </div>

      <div class="profile-identity">
        <div class="profile-username"><%= entity.username %></div>
        <% if (entity.display_name && entity.display_name !== entity.username) { %>
          <div class="profile-displayname">"<%= entity.display_name %>"</div>
        <% } %>
        <div class="profile-id">RBX: <%= entity.roblox_id %></div>
        <% if (p && p.created) { %>
          <div class="profile-created">Joined: <%= new Date(p.created).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' }) %></div>
        <% } %>
      </div>

      <div class="profile-badges-row">
        <strong class="govuk-tag govuk-tag--sev-<%= entity.severity.toLowerCase() %>"><%= entity.severity %></strong>
        <strong class="govuk-tag govuk-tag--status-<%= entity.status.toLowerCase() %>"><%= entity.status %></strong>
      </div>

      <% if (p) { %>
      <div class="stat-row-mini">
        <div class="mini-stat">
          <div class="mini-stat-val"><%= p.friends_count || 0 %></div>
          <div class="mini-stat-lbl">FRIENDS</div>
        </div>
        <div class="mini-stat">
          <div class="mini-stat-val"><%= p.followers_count || 0 %></div>
          <div class="mini-stat-lbl">FOLLOWERS</div>
        </div>
        <div class="mini-stat">
          <div class="mini-stat-val"><%= p.following_count || 0 %></div>
          <div class="mini-stat-lbl">FOLLOWING</div>
        </div>
      </div>
      <% } %>

      <% if (p && p.roblox_badges && p.roblox_badges.length > 0) { %>
      <div class="profile-section">
        <div class="section-label">ROBLOX BADGES</div>
        <div class="badge-list">
          <% p.roblox_badges.forEach(function(b) { %>
          <span class="roblox-badge" title="<%= b.description || b.name %>"><%= b.name %></span>
          <% }); %>
        </div>
      </div>
      <% } %>
    </div>

    <!-- Classification panel -->
    <div class="panel">
      <div class="panel-header"><span class="panel-title">CLASSIFICATION</span></div>
      <form action="/watchlist/<%= entity.id %>/update" method="POST" class="update-form">
        <div class="form-group-compact">
          <label class="form-label-sm">SEVERITY</label>
          <select class="form-input-sm" name="severity">
            <% ['LOW','MEDIUM','HIGH','CRITICAL'].forEach(function(s) { %>
            <option value="<%= s %>" <%= entity.severity === s ? 'selected' : '' %>><%= s %></option>
            <% }); %>
          </select>
        </div>
        <div class="form-group-compact">
          <label class="form-label-sm">STATUS</label>
          <select class="form-input-sm" name="status">
            <% ['ACTIVE','INACTIVE','ARCHIVED','BANNED'].forEach(function(s) { %>
            <option value="<%= s %>" <%= entity.status === s ? 'selected' : '' %>><%= s %></option>
            <% }); %>
          </select>
        </div>
        <div class="form-group-compact">
          <label class="form-label-sm">CATEGORY</label>
          <input class="form-input-sm" type="text" name="category" value="<%= entity.category %>">
        </div>
        <button class="btn btn-secondary btn-sm btn-full" type="submit">UPDATE CLASSIFICATION</button>
      </form>
    </div>
  </div>

  <!-- RIGHT: Detailed data -->
  <div class="profile-right">

    <!-- Refresh diff -->
    <% if (refreshDiff && Object.keys(refreshDiff).length > 0) { %>
    <div class="govuk-notification-banner govuk-notification-banner--info" style="margin-bottom:16px">
      <div class="govuk-notification-banner__header">API REFRESH — CHANGES DETECTED</div>
      <div class="govuk-notification-banner__content">
        <table style="width:100%;border-collapse:collapse;font-size:12px">
          <% Object.entries(refreshDiff).forEach(function([field, val]) { %>
          <tr>
            <td style="padding:3px 12px 3px 0;color:var(--mid-grey);font-family:var(--mono);font-size:10px;text-transform:uppercase;white-space:nowrap"><%= field %></td>
            <td style="padding:3px 8px 3px 0;color:#e08080;text-decoration:line-through"><%= val.from %></td>
            <td style="padding:3px 8px 3px 0;color:var(--mid-grey)">→</td>
            <td style="padding:3px 0;color:#5cb88a;font-weight:600"><%= val.to %></td>
          </tr>
          <% }); %>
        </table>
      </div>
    </div>
    <% } %>

    <!-- Shared group affiliations with other watched entities -->
    <% if (sharedWith && sharedWith.length > 0) { %>
    <div class="panel">
      <div class="panel-header">
        <span class="panel-title">NETWORK OVERLAP — SHARED GROUP AFFILIATIONS</span>
        <span class="govuk-tag govuk-tag--red"><%= sharedWith.length %> LINKED</span>
      </div>
      <div class="panel-body--compact">
        <% sharedWith.forEach(function(link) { %>
        <a href="/watchlist/<%= link.entity.id %>" class="entity-row">
          <div class="entity-avatar">
            <% if (link.entity.avatar_url) { %><img src="<%= link.entity.avatar_url %>" alt=""><% } else { %><span><%= link.entity.username.charAt(0).toUpperCase() %></span><% } %>
          </div>
          <div class="entity-info">
            <div class="entity-username"><%= link.entity.username %></div>
            <div class="entity-meta" style="font-size:11px">
              Shares <%= link.count %> group<%= link.count !== 1 ? 's' : '' %>:
              <% link.groupNames.slice(0,3).forEach(function(n) { %><span class="mini-tag"><%= n %></span><% }); %>
              <% if (link.groupNames.length > 3) { %><span style="color:var(--mid-grey)">+<%= link.groupNames.length - 3 %> more</span><% } %>
            </div>
          </div>
          <div class="entity-badges">
            <strong class="govuk-tag govuk-tag--sev-<%= link.entity.severity.toLowerCase() %>"><%= link.entity.severity %></strong>
            <strong class="govuk-tag govuk-tag--status-<%= link.entity.status.toLowerCase() %>"><%= link.entity.status %></strong>
          </div>
        </a>
        <% }); %>
      </div>
    </div>
    <% } %>

    <!-- Bio -->
    <% if (p && p.description) { %>
    <div class="panel">
      <div class="panel-header"><span class="panel-title">PROFILE DESCRIPTION</span></div>
      <div class="panel-body">
        <p class="bio-text"><%= p.description %></p>
      </div>
    </div>
    <% } %>

    <!-- Past usernames -->
    <% if (p && p.username_history && p.username_history.length > 0) { %>
    <div class="panel">
      <div class="panel-header"><span class="panel-title">PAST USERNAMES (<%= p.username_history.length %>)</span></div>
      <div class="panel-body">
        <div class="username-history">
          <% p.username_history.forEach(function(h) { %>
          <span class="past-username"><%= h.name %></span>
          <% }); %>
        </div>
      </div>
    </div>
    <% } %>

    <!-- Groups (collapsible) -->
    <% if (p && p.groups && p.groups.length > 0) { %>
    <div class="panel panel-collapsible" id="panel-groups">
      <button type="button" class="panel-header panel-toggle" data-panel="panel-groups" aria-expanded="true">
        <span class="panel-title">GROUP AFFILIATIONS (<%= p.groups.length %>)</span>
        <span class="panel-chevron-wrap">
          <svg class="panel-chevron" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
        </span>
      </button>
      <div class="panel-body panel-body--compact panel-collapsible__body">
        <% p.groups.forEach(function(g) { %>
        <div class="group-row">
          <div class="group-icon">
            <% if (g.group && g.group.memberCount) { %>
              <span class="group-count-badge"><%= g.group.memberCount > 999 ? Math.floor(g.group.memberCount/1000) + 'k' : g.group.memberCount %></span>
            <% } else { %>G<% } %>
          </div>
          <div class="group-info">
            <div class="group-name"><%= g.group ? g.group.name : 'Unknown Group' %></div>
            <div class="group-meta">
              Role: <strong><%= g.role ? g.role.name : '—' %></strong>
              <% if (g.group) { %> &bull; ID: <%= g.group.id %><% } %>
            </div>
          </div>
        </div>
        <% }); %>
      </div>
    </div>
    <% } %>

    <!-- Friends list -->
    <% if (p && p.friends_list && p.friends_list.length > 0) { %>
    <div class="panel">
      <div class="panel-header"><span class="panel-title">KNOWN ASSOCIATES (<%= p.friends_list.length %> shown)</span></div>
      <div class="panel-body">
        <div class="friends-grid">
          <% p.friends_list.slice(0, 24).forEach(function(f) { %>
          <div class="friend-chip" title="<%= f.name %>">
            <span class="friend-initial"><%= f.name.charAt(0).toUpperCase() %></span>
            <span class="friend-name"><%= f.name %></span>
          </div>
          <% }); %>
          <% if (p.friends_list.length > 24) { %>
          <div class="friend-chip friend-chip--more">+<%= p.friends_list.length - 24 %> more</div>
          <% } %>
        </div>
      </div>
    </div>
    <% } %>

    <!-- Games created (collapsible, collapsed by default if > 3) -->
    <% if (p && p.games && p.games.length > 0) { %>
    <div class="panel panel-collapsible <% if (p.games.length > 3) { %>panel-collapsible--collapsed<% } %>" id="panel-games">
      <button type="button" class="panel-header panel-toggle" data-panel="panel-games" aria-expanded="<%= p.games.length <= 3 ? 'true' : 'false' %>">
        <span class="panel-title">CREATED EXPERIENCES (<%= p.games.length %>)</span>
        <span class="panel-chevron-wrap">
          <svg class="panel-chevron" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
        </span>
      </button>
      <div class="panel-body panel-body--compact panel-collapsible__body">
        <% p.games.forEach(function(g) { %>
        <div class="game-row">
          <div class="game-info">
            <div class="game-name"><%= g.name %></div>
            <div class="game-meta">
              <% if (g.placeVisits !== undefined) { %>Visits: <strong><%= g.placeVisits.toLocaleString() %></strong> &bull; <% } %>
              <% if (g.created) { %>Created: <%= new Date(g.created).toLocaleDateString('en-GB') %><% } %>
            </div>
          </div>
          <% if (g.rootPlaceId) { %>
          <a href="https://www.roblox.com/games/<%= g.rootPlaceId %>" target="_blank" rel="noopener" class="table-action-btn">VIEW</a>
          <% } %>
        </div>
        <% }); %>
      </div>
    </div>
    <% } %>

    <!-- Case log (replaces single notes textarea) -->
    <div class="panel" id="case-log">
      <div class="panel-header">
        <span class="panel-title">CASE LOG</span>
        <span class="govuk-tag govuk-tag--grey"><%= caseNotes.length %> ENTR<%= caseNotes.length !== 1 ? 'IES' : 'Y' %></span>
      </div>
      <div class="panel-body">
        <form action="/watchlist/<%= entity.id %>/notes" method="POST" class="note-add-form">
          <textarea class="form-input form-textarea" name="note" rows="3" placeholder="Add a case note, incident reference, or intelligence update…" required></textarea>
          <button class="btn btn-secondary btn-sm" type="submit" style="margin-top:.5rem">ADD ENTRY</button>
        </form>
      </div>
      <% if (caseNotes.length > 0) { %>
      <div class="panel-body--compact" style="border-top:1px solid var(--border);padding-top:0">
        <% caseNotes.forEach(function(n) { %>
        <div class="case-note">
          <div class="case-note-meta">
            <span class="case-note-author"><%= n.author %></span>
            <span class="case-note-time"><%= new Date(n.created_at).toLocaleString('en-GB') %></span>
            <% if (n.author === user.username || user.role === 'admin') { %>
            <form action="/watchlist/<%= entity.id %>/notes/delete" method="POST" style="display:inline;margin-left:auto">
              <input type="hidden" name="note_id" value="<%= n.id %>">
              <button type="submit" class="case-note-delete" title="Delete note" onclick="return confirm('Delete this note?')">&times;</button>
            </form>
            <% } %>
          </div>
          <div class="case-note-body"><%= n.note %></div>
        </div>
        <% }); %>
      </div>
      <% } else { %>
      <div class="empty-state" style="padding:12px 16px;font-size:12px">No case notes yet.</div>
      <% } %>
    </div>

    <!-- Threat timeline -->
    <% if (snapshots && snapshots.length > 0) { %>
    <div class="panel panel-collapsible panel-collapsible--collapsed" id="panel-timeline">
      <button type="button" class="panel-header panel-toggle" data-panel="panel-timeline" aria-expanded="false">
        <span class="panel-title">THREAT TIMELINE (<%= snapshots.length %> SNAPSHOTS)</span>
        <span class="panel-chevron-wrap">
          <svg class="panel-chevron" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
        </span>
      </button>
      <div class="panel-body panel-body--compact panel-collapsible__body">
        <% snapshots.forEach(function(snap, i) { %>
        <div class="timeline-entry">
          <div class="timeline-dot <%= snap.diff && Object.keys(snap.diff).length > 0 ? 'timeline-dot--changed' : '' %>"></div>
          <div class="timeline-content">
            <div class="timeline-header">
              <span class="timeline-time"><%= new Date(snap.fetched_at).toLocaleString('en-GB') %></span>
              <span class="timeline-by">by <%= snap.fetched_by %></span>
              <% if (i === 0) { %><span class="govuk-tag govuk-tag--grey" style="font-size:9px">LATEST</span><% } %>
            </div>
            <% if (snap.diff && Object.keys(snap.diff).length > 0) { %>
            <div class="timeline-changes">
              <% Object.entries(snap.diff).forEach(function([field, val]) { %>
              <span class="timeline-change">
                <span class="timeline-field"><%= field %></span>
                <span class="timeline-from"><%= val.from %></span>
                <span class="timeline-arrow">→</span>
                <span class="timeline-to"><%= val.to %></span>
              </span>
              <% }); %>
            </div>
            <% } else { %>
            <div class="timeline-no-change">No changes detected</div>
            <% } %>
          </div>
        </div>
        <% }); %>
      </div>
    </div>
    <% } %>

    <!-- Tags -->
    <div class="panel">
      <div class="panel-header"><span class="panel-title">INTELLIGENCE TAGS</span></div>
      <div class="panel-body">
        <div class="tags-row" style="margin-bottom:.75rem">
          <% if (entity.tags && entity.tags.length > 0) { %>
            <% entity.tags.forEach(function(t) { %>
            <span class="tag-pill">
              <%= t.tag %>
              <form action="/watchlist/<%= entity.id %>/tags/remove" method="POST" style="display:inline">
                <input type="hidden" name="tag" value="<%= t.tag %>">
                <button type="submit" class="tag-remove" title="Remove tag">&times;</button>
              </form>
            </span>
            <% }); %>
          <% } else { %>
            <span class="text-muted">No tags assigned.</span>
          <% } %>
        </div>
        <form action="/watchlist/<%= entity.id %>/tags" method="POST" class="tag-add-form">
          <input class="form-input-sm" type="text" name="tag" placeholder="ADD TAG…" maxlength="30" required>
          <button class="btn btn-secondary btn-sm" type="submit">ADD</button>
        </form>
      </div>
    </div>

    <!-- Audit history (collapsible, collapsed by default) -->
    <% if (auditHistory && auditHistory.length > 0) { %>
    <div class="panel panel-collapsible panel-collapsible--collapsed" id="panel-audit">
      <button type="button" class="panel-header panel-toggle" data-panel="panel-audit" aria-expanded="false">
        <span class="panel-title">AUDIT HISTORY (<%= auditHistory.length %>)</span>
        <span class="panel-chevron-wrap">
          <svg class="panel-chevron" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
        </span>
      </button>
      <div class="panel-body panel-body--compact panel-collapsible__body">
        <% auditHistory.forEach(function(log) { %>
        <div class="audit-row">
          <span class="audit-action-badge"><%= log.action.replace(/_/g, ' ') %></span>
          <span class="audit-actor"><%= log.actor %></span>
          <span class="audit-time"><%= new Date(log.created_at).toLocaleString('en-GB') %></span>
        </div>
        <% }); %>
      </div>
    </div>
    <% } %>

    <!-- Danger zone -->
    <div class="panel panel-danger">
      <div class="panel-header"><span class="panel-title">DANGER ZONE</span></div>
      <div class="panel-body">
        <p class="danger-text">Permanently remove this entity from the intelligence registry. This action cannot be undone.</p>
        <form action="/watchlist/<%= entity.id %>/delete" method="POST" onsubmit="return confirm('Remove <%= entity.username %> from the registry? This cannot be undone.')">
          <button class="btn btn-danger" type="submit">PURGE ENTITY FROM REGISTRY</button>
        </form>
      </div>
    </div>

  </div>
</div>

<div class="profile-meta">
  Last updated: <%= entity.last_fetched ? new Date(entity.last_fetched).toLocaleString('en-GB') : 'Never' %> &bull;
  Added by: <%= entity.added_by %> on <%= new Date(entity.added_at).toLocaleDateString('en-GB') %>
</div>

<%- include('../partials/footer') %>
