<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Initial Setup — HM Intelligence Database</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="auth-body">
  <div class="auth-container">
    <div class="auth-header">
      <div class="gov-logo auth-logo">
        <svg class="crown-icon" viewBox="0 0 32 32" fill="none">
          <path d="M16 2L19 9H26L20.5 13.5L22.5 20.5L16 16.5L9.5 20.5L11.5 13.5L6 9H13L16 2Z" fill="currentColor"/>
          <rect x="6" y="22" width="20" height="3" rx="1" fill="currentColor"/>
          <rect x="4" y="26" width="24" height="3" rx="1" fill="currentColor"/>
        </svg>
        <div class="gov-text">
          <span class="gov-dept">HM GOVERNMENT</span>
          <span class="gov-name">Intelligence Database</span>
        </div>
      </div>
    </div>

    <div class="auth-card">
      <h1 class="auth-title">INITIAL SYSTEM SETUP</h1>
      <p class="auth-subtitle">Create the first administrator account. Requires the setup token from your environment configuration.</p>

      <% if (error) { %>
      <div class="alert alert-error"><%= error %></div>
      <% } %>

      <form action="/setup" method="POST" class="auth-form">
        <div class="form-group">
          <label class="form-label" for="token">SETUP TOKEN</label>
          <input class="form-input" type="password" id="token" name="token" required>
          <span class="form-hint">Found in your SETUP_TOKEN environment variable.</span>
        </div>
        <div class="form-group">
          <label class="form-label" for="username">ADMIN USERNAME</label>
          <input class="form-input" type="text" id="username" name="username" required>
        </div>
        <div class="form-group">
          <label class="form-label" for="display_name">DISPLAY NAME</label>
          <input class="form-input" type="text" id="display_name" name="display_name">
        </div>
        <div class="form-group">
          <label class="form-label" for="password">PASSWORD (min 8 chars)</label>
          <input class="form-input" type="password" id="password" name="password" minlength="8" required>
        </div>
        <button class="btn btn-primary btn-full" type="submit">CREATE ADMINISTRATOR &rarr;</button>
      </form>
    </div>
  </div>
</body>
</html>
