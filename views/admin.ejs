<%- include('partials/header', { pageTitle: 'User Management', page: 'admin' }) %>

<div class="govuk-page-header">
  <div>
    <span class="govuk-caption-m">SYSTEM ADMINISTRATION</span>
    <h1 class="govuk-heading-xl">Operator Management</h1>
  </div>
</div>

<% if (error) { %>
<div class="govuk-notification-banner govuk-notification-banner--error" style="margin-bottom:1.5rem">
  <div class="govuk-notification-banner__header">ERROR</div>
  <div class="govuk-notification-banner__content"><%= error %></div>
</div>
<% } %>
<% if (success) { %>
<div class="govuk-notification-banner govuk-notification-banner--success" style="margin-bottom:1.5rem">
  <div class="govuk-notification-banner__header">SUCCESS</div>
  <div class="govuk-notification-banner__content"><%= success %></div>
</div>
<% } %>

<div class="admin-grid">
  <!-- Register new operator form -->
  <div class="panel">
    <div class="panel-header"><span class="panel-title">REGISTER NEW OPERATOR</span></div>
    <div class="panel-body">
      <form action="/admin/users/add" method="POST" class="intel-form" id="add-operator-form">
        <div class="form-group-compact">
          <label class="form-label-sm">USERNAME <span class="required">*</span></label>
          <input class="form-input-sm" type="text" name="username" required autocomplete="off">
        </div>
        <div class="form-group-compact">
          <label class="form-label-sm">DISPLAY NAME</label>
          <input class="form-input-sm" type="text" name="display_name" autocomplete="off">
        </div>
        <div class="form-group-compact">
          <label class="form-label-sm">PASSWORD <span class="required">*</span> <span class="form-hint-inline">(min 8 chars)</span></label>
          <input class="form-input-sm" type="password" name="password" minlength="8" required autocomplete="new-password">
        </div>

        <!-- Role title (free text) -->
        <div class="form-group-compact">
          <label class="form-label-sm">ROLE TITLE <span class="required">*</span> <span class="form-hint-inline">(type anything — e.g. Handler, Trainee, Controller)</span></label>
          <input class="form-input-sm" type="text" name="role" id="new-user-role-val"
                 value="Analyst" required autocomplete="off" placeholder="e.g. Analyst, Handler, Trainee…">
        </div>

        <!-- Permission presets -->
        <div class="form-group-compact">
          <label class="form-label-sm">PERMISSION PRESET <span class="form-hint-inline">(click to pre-fill permissions below)</span></label>
          <div class="role-cards">

            <label class="role-card" data-role="viewer">
              <input type="radio" name="_role_display" value="viewer" class="role-card-radio">
              <div class="role-card-inner">
                <div class="role-card-top">
                  <span class="role-card-badge role-viewer">VIEWER</span>
                  <span class="role-card-default">READ ONLY</span>
                </div>
                <ul class="role-card-perms">
                  <li>&#10003; View entities &amp; dossiers</li>
                  <li>&#10003; Browse audit logs</li>
                  <li>&#10007; Cannot add or edit</li>
                  <li>&#10007; No bulk actions</li>
                </ul>
              </div>
            </label>

            <label class="role-card role-card--selected" data-role="analyst">
              <input type="radio" name="_role_display" value="analyst" class="role-card-radio" checked>
              <div class="role-card-inner">
                <div class="role-card-top">
                  <span class="role-card-badge role-analyst">ANALYST</span>
                  <span class="role-card-default">DEFAULT</span>
                </div>
                <ul class="role-card-perms">
                  <li>&#10003; All VIEWER permissions</li>
                  <li>&#10003; Add &amp; edit entities</li>
                  <li>&#10003; Refresh profiles</li>
                  <li>&#10007; No user management</li>
                </ul>
              </div>
            </label>

            <label class="role-card" data-role="admin">
              <input type="radio" name="_role_display" value="admin" class="role-card-radio">
              <div class="role-card-inner">
                <div class="role-card-top">
                  <span class="role-card-badge role-admin">ADMIN</span>
                  <span class="role-card-default">FULL ACCESS</span>
                </div>
                <ul class="role-card-perms">
                  <li>&#10003; Full portal access</li>
                  <li>&#10003; Bulk actions</li>
                  <li>&#10003; Manage operators</li>
                  <li>&#10003; Scheduler control</li>
                </ul>
              </div>
            </label>

          </div>
        </div>

        <!-- Permission checkboxes -->
        <div class="perm-group" style="margin-top:.75rem">
          <div class="perm-group-label">PERMISSIONS <span class="form-hint-inline">(auto-set from role, or customise)</span></div>
          <% PERMISSIONS.forEach(function(p) { %>
          <label class="perm-check" data-perm-key="<%= p.key %>">
            <input type="checkbox" name="perm_<%= p.key %>"
              <%= (ROLE_PERMISSIONS['analyst'] || []).includes(p.key) ? 'checked' : '' %>
              class="perm-input perm-new">
            <span class="perm-label"><%= p.label %></span>
            <span class="perm-desc"><%= p.desc %></span>
          </label>
          <% }); %>
        </div>

        <button class="btn btn-primary btn-sm" type="submit" style="margin-top:.75rem">REGISTER OPERATOR</button>
      </form>
    </div>
  </div>

  <!-- Operators table -->
  <div class="panel" style="overflow:visible">
    <div class="panel-header">
      <span class="panel-title">REGISTERED OPERATORS (<%= users.length %>)</span>
    </div>
    <table class="registry-table">
      <thead>
        <tr>
          <th>OPERATOR</th>
          <th>CLEARANCE</th>
          <th>LAST ACCESS</th>
          <th>REGISTERED BY</th>
          <th>ACTIONS</th>
        </tr>
      </thead>
      <tbody>
        <% users.forEach(function(u) { %>
        <tr>
          <td>
            <div style="display:flex;align-items:center;gap:.5rem">
              <div class="user-avatar-sm"><%= u.username.charAt(0).toUpperCase() %></div>
              <div>
                <div class="table-username"><%= u.display_name || u.username %></div>
                <div class="table-meta">@<%= u.username %></div>
              </div>
            </div>
          </td>
          <td>
            <span class="role-badge role-<%= u.role %>"><%= u.role.toUpperCase() %></span>
          </td>
          <td class="mono text-muted" style="font-size:10px">
            <%= u.last_login ? new Date(u.last_login).toLocaleString('en-GB') : 'Never' %>
          </td>
          <td class="mono text-muted" style="font-size:10px"><%= u.created_by || '—' %></td>
          <td>
            <div class="action-group">
              <% if (String(u.id) !== String(user.id)) { %>
              <form action="/admin/users/<%= u.id %>/change-role" method="POST"
                    style="display:inline-flex;gap:.3rem;align-items:center">
                <input class="form-input-xs" type="text" name="role"
                       value="<%= u.role %>" style="width:90px" title="Role title — type anything"
                       autocomplete="off">
                <button class="btn btn-secondary btn-xs" type="submit">SET</button>
              </form>
              <form action="/admin/users/<%= u.id %>/delete" method="POST" style="display:inline"
                    onsubmit="return confirm('Delete operator <%= u.username %>? This cannot be undone.')">
                <button class="btn btn-danger btn-xs" type="submit">DELETE</button>
              </form>
              <% } else { %>
              <span class="text-muted" style="font-size:11px;padding:0 .5rem">YOU</span>
              <% } %>
              <button class="btn btn-secondary btn-xs" type="button" onclick="toggleSection('reset-<%= u.id %>')">RESET PW</button>
              <button class="btn btn-ghost btn-xs" type="button" onclick="toggleSection('perms-<%= u.id %>')">PERMISSIONS</button>
            </div>

            <!-- Reset password inline -->
            <div id="reset-<%= u.id %>" style="display:none;margin-top:.4rem">
              <form action="/admin/users/<%= u.id %>/reset-password" method="POST" style="display:flex;gap:.4rem;align-items:center">
                <input class="form-input-xs" type="password" name="new_password" placeholder="New password" minlength="8" required style="flex:1;min-width:120px">
                <button class="btn btn-secondary btn-xs" type="submit">SET</button>
                <button class="btn btn-ghost btn-xs" type="button" onclick="toggleSection('reset-<%= u.id %>')">CANCEL</button>
              </form>
            </div>

            <!-- Permissions inline -->
            <div id="perms-<%= u.id %>" style="display:none;margin-top:.75rem">
              <form action="/admin/users/<%= u.id %>/permissions" method="POST">
                <div class="perm-group perm-group--compact">
                  <div class="perm-group-label" style="margin-bottom:.4rem">
                    OPERATOR PERMISSIONS
                    <% if (String(u.id) !== String(user.id)) { %>
                    <span style="margin-left:.5rem">
                      <button type="button" class="perm-preset-btn" onclick="applyRolePreset('<%= u.role %>', 'u<%= u.id %>')">RESET TO ROLE DEFAULTS</button>
                    </span>
                    <% } %>
                  </div>
                  <% const userPerms = u.permissions || []; %>
                  <% PERMISSIONS.forEach(function(p) { %>
                  <label class="perm-check perm-check--sm" data-perm-key="<%= p.key %>">
                    <input type="checkbox" name="perm_<%= p.key %>"
                      <%= userPerms.includes(p.key) ? 'checked' : '' %>
                      class="perm-input perm-u<%= u.id %>"
                      <% if (String(u.id) === String(user.id)) { %>disabled<% } %>>
                    <span class="perm-label"><%= p.label %></span>
                    <span class="perm-desc"><%= p.desc %></span>
                  </label>
                  <% }); %>
                </div>
                <% if (String(u.id) !== String(user.id)) { %>
                <div style="display:flex;gap:.4rem;margin-top:.5rem">
                  <button class="btn btn-secondary btn-xs" type="submit">SAVE PERMISSIONS</button>
                  <button class="btn btn-ghost btn-xs" type="button" onclick="toggleSection('perms-<%= u.id %>')">CANCEL</button>
                </div>
                <% } else { %>
                <p class="form-hint" style="margin-top:.4rem">You cannot modify your own permissions.</p>
                <button class="btn btn-ghost btn-xs" type="button" onclick="toggleSection('perms-<%= u.id %>')">CLOSE</button>
                <% } %>
              </form>
            </div>
          </td>
        </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
</div>

<script>
const ROLE_PERMISSIONS = <%- JSON.stringify(ROLE_PERMISSIONS) %>;

function applyRolePreset(role, group) {
  const perms = ROLE_PERMISSIONS[role] || [];
  const inputs = document.querySelectorAll('.perm-' + group);
  inputs.forEach(function(input) {
    const key = input.closest('.perm-check')?.dataset.permKey;
    if (key) input.checked = perms.includes(key);
  });
}

function toggleSection(id) {
  const el = document.getElementById(id);
  if (!el) return;
  const isHidden = el.style.display === 'none' || el.style.display === '';
  el.style.display = isHidden ? 'block' : 'none';
}

// Role cards — apply permission preset + suggest role name in text field + highlight card
document.querySelectorAll('.role-card-radio').forEach(function(radio) {
  radio.addEventListener('change', function() {
    const preset = this.value; // viewer / analyst / admin
    // Apply permission checkboxes for this preset
    applyRolePreset(preset, 'new');
    // Suggest the preset name in the role title field (capitalised), user can edit freely
    const roleInput = document.getElementById('new-user-role-val');
    if (roleInput) {
      roleInput.value = preset.charAt(0).toUpperCase() + preset.slice(1);
    }
    // Highlight selected card
    document.querySelectorAll('.role-card').forEach(function(card) {
      card.classList.toggle('role-card--selected', card.dataset.role === preset);
    });
  });
});
</script>

<%- include('partials/footer') %>
