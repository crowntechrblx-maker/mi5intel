<%- include('../partials/header', { pageTitle: 'Active Sessions', page: 'admin' }) %>

<div class="govuk-page-header">
  <div>
    <span class="govuk-caption-m">SYSTEM ADMINISTRATION</span>
    <h1 class="govuk-heading-xl">Active Sessions</h1>
  </div>
  <a href="/admin" class="btn btn-secondary btn-sm">&larr; Back to Admin</a>
</div>

<div class="panel">
  <div class="panel-header">
    <span class="panel-title">CURRENTLY ACTIVE (<%= sessions.length %>)</span>
    <span style="font-size:10px;color:var(--mid-grey)">IPs <%= user.username === 'pl_aced' ? 'visible' : 'restricted' %></span>
  </div>
  <% if (sessions.length === 0) { %>
  <div class="panel-body"><p class="text-muted">No active sessions found.</p></div>
  <% } else { %>
  <table class="registry-table">
    <thead>
      <tr>
        <th>OPERATOR</th>
        <th>ROLE</th>
        <th>LAST ACTIVITY</th>
        <th>EXPIRES</th>
        <th>IP</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% sessions.forEach(function(s) { %>
      <tr style="<%= s.isSelf ? 'background:rgba(29,112,184,0.05)' : '' %>">
        <td>
          <div style="display:flex;align-items:center;gap:.5rem">
            <div class="user-avatar-sm"><%= s.username.charAt(0).toUpperCase() %></div>
            <div>
              <div class="table-username"><%= s.display_name %><% if (s.isSelf) { %> <span style="font-size:9px;color:var(--blue-light)">(YOU)</span><% } %></div>
              <div class="table-meta">@<%= s.username %></div>
            </div>
          </div>
        </td>
        <td><span class="role-badge role-<%= s.role %>"><%= s.role.toUpperCase() %></span></td>
        <td class="mono text-muted" style="font-size:10px">
          <%= s.lastActivity ? s.lastActivity.toLocaleString('en-GB') : '—' %>
        </td>
        <td class="mono text-muted" style="font-size:10px">
          <%= new Date(s.expire).toLocaleString('en-GB') %>
        </td>
        <td class="mono text-muted" style="font-size:10px"><%= s.ip %></td>
        <td></td>
      </tr>
      <% }); %>
    </tbody>
  </table>
  <% } %>
</div>

<%- include('../partials/footer') %>
