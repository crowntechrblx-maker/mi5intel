<%- include('partials/header', { pageTitle: 'Audit Logs', page: 'audit' }) %>

<div class="govuk-page-header">
  <div>
    <span class="govuk-caption-m">SYSTEM RECORDS</span>
    <h1 class="govuk-heading-xl">Audit Logs</h1>
  </div>
</div>

<div class="filter-bar">
  <form action="/audit" method="GET" class="filter-form">
    <input class="search-input" type="text" name="actor" value="<%= filters.actor || '' %>" placeholder="Filter by operator...">
    <select name="action" class="filter-select">
      <option value="">ALL ACTIONS</option>
      <% ['LOGIN','LOGOUT','FAILED_LOGIN','ADD_ENTITY','VIEW_ENTITY','UPDATE_ENTITY','REFRESH_ENTITY','DELETE_ENTITY','CREATE_USER','DELETE_USER','CHANGE_ROLE','RESET_PASSWORD'].forEach(function(a) { %>
      <option value="<%= a %>" <%= filters.action === a ? 'selected' : '' %>><%= a.replace(/_/g,' ') %></option>
      <% }); %>
    </select>
    <button type="submit" class="btn btn-secondary btn-sm">FILTER</button>
    <a href="/audit" class="btn btn-ghost btn-sm">CLEAR</a>
  </form>
</div>

<div class="registry-table-wrap">
  <table class="registry-table">
    <thead>
      <tr>
        <th>#</th>
        <th>ACTION</th>
        <th>OPERATOR</th>
        <th>TARGET</th>
        <th>DETAILS</th>
        <th>IP ADDRESS</th>
        <th>TIMESTAMP</th>
      </tr>
    </thead>
    <tbody>
      <% if (logs.length === 0) { %>
      <tr><td colspan="7" class="empty-row">NO AUDIT RECORDS MATCH CURRENT FILTER PARAMETERS</td></tr>
      <% } else { %>
      <% logs.forEach(function(log) { %>
      <tr>
        <td class="mono text-muted"><%= log.id %></td>
        <td><span class="audit-action-badge audit-<%= log.action.toLowerCase().replace(/_/g,'-') %>"><%= log.action.replace(/_/g,' ') %></span></td>
        <td class="table-username"><%= log.actor %></td>
        <td class="mono"><%= log.target || '—' %></td>
        <td class="text-muted"><%= log.details || '—' %></td>
        <td class="mono text-muted"><%= log.ip_address || '—' %></td>
        <td class="mono text-muted"><%= new Date(log.created_at).toLocaleString('en-GB') %></td>
      </tr>
      <% }); %>
      <% } %>
    </tbody>
  </table>
</div>

<div class="table-footer">
  <span class="table-count">Showing <%= offset + 1 %>–<%= Math.min(offset + limit, total) %> of <%= total %> records</span>
  <div class="pagination">
    <% if (offset > 0) { %>
    <a href="/audit?page=<%= Math.floor(offset/limit) %>&actor=<%= filters.actor||'' %>&action=<%= filters.action||'' %>" class="btn btn-ghost btn-sm">← PREV</a>
    <% } %>
    <% if (offset + limit < total) { %>
    <a href="/audit?page=<%= Math.floor(offset/limit) + 2 %>&actor=<%= filters.actor||'' %>&action=<%= filters.action||'' %>" class="btn btn-ghost btn-sm">NEXT →</a>
    <% } %>
  </div>
</div>

<%- include('partials/footer') %>
