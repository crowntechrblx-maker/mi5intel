<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof pageTitle !== 'undefined' ? pageTitle + ' — ' : '' %>HM Intelligence Database</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" href="/favicon.svg" type="image/svg+xml">
</head>
<body>

<!-- GOV.UK Header -->
<header class="govuk-header" role="banner">
  <div class="govuk-header__container">
    <a href="/" class="govuk-header__logotype" aria-label="HM Government Intelligence Database — Home">
      <!-- GOV.UK Crown -->
      <svg class="crown-icon" viewBox="0 0 132 97" focusable="false" aria-hidden="true">
        <path fill="currentColor" d="M25 30.2c3.5 1.5 7.7-.2 9.1-3.7 1.5-3.6-.2-7.8-3.9-9.2-3.6-1.4-7.6.3-9.1 3.9-1.4 3.5.3 7.5 3.9 9zm40.9 0c3.6-1.4 5.3-5.4 3.9-9s-5.5-5.3-9.1-3.9c-3.6 1.4-5.3 5.4-3.9 9 1.4 3.6 5.5 5.3 9.1 3.9zm-24-3.6c-.3 3.8 2.8 7.1 6.7 7.4 3.8.3 7.1-2.8 7.4-6.6.3-3.8-2.8-7.1-6.7-7.4-3.8-.3-7.1 2.8-7.4 6.6zm-6.6 30.8L30 55c-1.8 0-3.2-1.4-3.2-3.2l-.1-6.1c0-1.8 1.4-3.2 3.2-3.2H44c1.8 0 3.2 1.4 3.2 3.2l.1 6.1c0 1.8-1.4 3.2-3.2 3.2H35.3zm40.9 0L66 55c-1.8 0-3.2-1.4-3.2-3.2l-.1-6.1c0-1.8 1.4-3.2 3.2-3.2h13.1c1.8 0 3.2 1.4 3.2 3.2l.1 6.1c0 1.8-1.4 3.2-3.2 3.2H76.2zm-33 18.2l-7.5 9.7c-4.7 1.4-9.6.3-13.1-3.2-3.5-3.5-4.6-8.5-3.1-13.1l9.5-7.8v14.4h14.2zm25.9 0L99 75.6c.8 4.6-.8 9.4-4.2 12.8-3.4 3.4-8.2 5-12.8 4.2L75 84v-14.4h14.4zm-13.4 0H59.2V57.8h21.6v18.2h-1.3zM0 30.2l3.1 3.2c0-4.1 3.3-7.4 7.4-7.4s7.4 3.3 7.4 7.4-3.3 7.4-7.4 7.4l-3.1-3.2C3.3 41 0 44.3 0 48.4s3.3 7.4 7.4 7.4h4.7l3.1 3.2H0V97h132V59l-11.4-3.2 3.1-3.2h4.7c4.1 0 7.4-3.3 7.4-7.4s-3.3-7.4-7.4-7.4l-3.1 3.2c4.1 0 7.4 3.3 7.4 7.4s-3.3 7.4-7.4 7.4-7.4-3.3-7.4-7.4l3.1-3.2H132V30.2L66 0 0 30.2z"/>
      </svg>
      <div class="govuk-header__logotype-text">
        <span class="govuk-header__logotype-dept">HM Government</span>
        <span class="govuk-header__logotype-name">Intelligence Database</span>
      </div>
    </a>

    <div class="govuk-header__divider" aria-hidden="true"></div>

    <span class="govuk-header__service-name">CLASSIFIED SYSTEM</span>

    <div class="govuk-header__right">
      <span class="govuk-phase-tag">RESTRICTED</span>
      <div class="header-user">
        <div class="header-avatar"><%= user ? user.username.charAt(0).toUpperCase() : '?' %></div>
        <span style="display:none;font-size:12px;color:var(--text-secondary)"><%= user ? (user.display_name || user.username) : '' %></span>
      </div>
    </div>
  </div>
</header>

<!-- Service Navigation (Sidebar) -->
<nav class="govuk-service-nav" aria-label="Service navigation">
  <div class="govuk-service-nav__section">
    <span class="govuk-service-nav__section-label">OPERATIONS</span>
    <a href="/" class="govuk-service-nav__item <%= page === 'dashboard' ? 'govuk-service-nav__item--active' : '' %>">
      <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
        <path d="M3 4a1 1 0 011-1h12a1 1 0 011 1v2a1 1 0 01-1 1H4a1 1 0 01-1-1V4zM3 10a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H4a1 1 0 01-1-1v-6zM14 9a1 1 0 00-1 1v6a1 1 0 001 1h2a1 1 0 001-1v-6a1 1 0 00-1-1h-2z"/>
      </svg>
      Intelligence Desk
    </a>
    <a href="/watchlist" class="govuk-service-nav__item <%= page === 'watchlist' ? 'govuk-service-nav__item--active' : '' %>">
      <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
        <path d="M9 6a3 3 0 11-6 0 3 3 0 016 0zM17 6a3 3 0 11-6 0 3 3 0 016 0zM12.93 17c.046-.327.07-.66.07-1a6.97 6.97 0 00-1.5-4.33A5 5 0 0119 16v1h-6.07zM6 11a5 5 0 015 5v1H1v-1a5 5 0 015-5z"/>
      </svg>
      Watchlist
    </a>
    <a href="/network" class="govuk-service-nav__item <%= page === 'network' ? 'govuk-service-nav__item--active' : '' %>">
      <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
        <path fill-rule="evenodd" d="M12.316 3.051a1 1 0 01.633 1.265l-4 12a1 1 0 11-1.898-.632l4-12a1 1 0 011.265-.633zM5.707 6.293a1 1 0 010 1.414L3.414 10l2.293 2.293a1 1 0 11-1.414 1.414l-3-3a1 1 0 010-1.414l3-3a1 1 0 011.414 0zm8.586 0a1 1 0 011.414 0l3 3a1 1 0 010 1.414l-3 3a1 1 0 11-1.414-1.414L16.586 10l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd"/>
      </svg>
      Network View
    </a>
  </div>

  <div class="govuk-service-nav__section">
    <span class="govuk-service-nav__section-label">RECORDS</span>
    <a href="/audit" class="govuk-service-nav__item <%= page === 'audit' ? 'govuk-service-nav__item--active' : '' %>">
      <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
        <path fill-rule="evenodd" d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4z" clip-rule="evenodd"/>
      </svg>
      Audit Logs
    </a>
    <% if (user && user.role === 'admin') { %>
    <a href="/admin" class="govuk-service-nav__item <%= page === 'admin' ? 'govuk-service-nav__item--active' : '' %>">
      <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
        <path d="M13 6a3 3 0 11-6 0 3 3 0 016 0zM18 8a2 2 0 11-4 0 2 2 0 014 0zM14 15a4 4 0 00-8 0v3h8v-3zM6 8a2 2 0 11-4 0 2 2 0 014 0zM16 18v-3a5.972 5.972 0 00-.75-2.906A3.005 3.005 0 0119 15v3h-3zM4.75 12.094A5.973 5.973 0 004 15v3H1v-3a3 3 0 013.75-2.906z"/>
      </svg>
      User Management
    </a>
    <% } %>
    <a href="/settings" class="govuk-service-nav__item <%= page === 'settings' ? 'govuk-service-nav__item--active' : '' %>">
      <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
        <path fill-rule="evenodd" d="M11.49 3.17c-.38-1.56-2.6-1.56-2.98 0a1.532 1.532 0 01-2.286.948c-1.372-.836-2.942.734-2.106 2.106.54.886.061 2.042-.947 2.287-1.561.379-1.561 2.6 0 2.978a1.532 1.532 0 01.947 2.287c-.836 1.372.734 2.942 2.106 2.106a1.532 1.532 0 012.287.947c.379 1.561 2.6 1.561 2.978 0a1.533 1.533 0 012.287-.947c1.372.836 2.942-.734 2.106-2.106a1.533 1.533 0 01.947-2.287c1.561-.379 1.561-2.6 0-2.978a1.532 1.532 0 01-.947-2.287c.836-1.372-.734-2.942-2.106-2.106a1.532 1.532 0 01-2.287-.947zM10 13a3 3 0 100-6 3 3 0 000 6z" clip-rule="evenodd"/>
      </svg>
      Settings
    </a>
  </div>

  <div class="govuk-service-nav__footer">
    <div class="nav-avatar"><%= user ? user.username.charAt(0).toUpperCase() : '?' %></div>
    <div class="nav-user-info">
      <span class="nav-user-name"><%= user ? (user.display_name || user.username) : 'Unknown' %></span>
      <span class="nav-user-role"><%= user ? user.role.toUpperCase() : '' %></span>
    </div>
    <form action="/logout" method="POST">
      <button type="submit" class="nav-logout-btn" title="Sign out">
        <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path fill-rule="evenodd" d="M3 3a1 1 0 00-1 1v12a1 1 0 102 0V4a1 1 0 00-1-1zm10.293 9.293a1 1 0 001.414 1.414l3-3a1 1 0 000-1.414l-3-3a1 1 0 10-1.414 1.414L14.586 9H7a1 1 0 100 2h7.586l-1.293 1.293z" clip-rule="evenodd"/>
        </svg>
      </button>
    </form>
  </div>
</nav>

<main class="govuk-main-wrapper" id="main-content" role="main">
