<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof pageTitle !== 'undefined' ? pageTitle + ' — ' : '' %>HM Intelligence Database</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" href="/favicon.svg" type="image/svg+xml">
</head>
<body>
<aside class="sidebar">
  <div class="sidebar-header">
    <div class="gov-logo">
      <svg class="crown-icon" viewBox="0 0 32 32" fill="none">
        <path d="M16 2L19 9H26L20.5 13.5L22.5 20.5L16 16.5L9.5 20.5L11.5 13.5L6 9H13L16 2Z" fill="currentColor"/>
        <rect x="6" y="22" width="20" height="3" rx="1" fill="currentColor"/>
        <rect x="4" y="26" width="24" height="3" rx="1" fill="currentColor"/>
      </svg>
      <div class="gov-text">
        <span class="gov-dept">HM GOVERNMENT</span>
        <span class="gov-name">Intelligence Database</span>
      </div>
    </div>
    <div class="classification-badge">RESTRICTED — INTERNAL ONLY</div>
  </div>

  <nav class="sidebar-nav">
    <a href="/" class="nav-item <%= page === 'dashboard' ? 'active' : '' %>">
      <svg viewBox="0 0 20 20" fill="currentColor"><path d="M3 4a1 1 0 011-1h12a1 1 0 011 1v2a1 1 0 01-1 1H4a1 1 0 01-1-1V4zM3 10a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H4a1 1 0 01-1-1v-6zM14 9a1 1 0 00-1 1v6a1 1 0 001 1h2a1 1 0 001-1v-6a1 1 0 00-1-1h-2z"/></svg>
      Intelligence Desk
    </a>
    <a href="/watchlist" class="nav-item <%= page === 'watchlist' ? 'active' : '' %>">
      <svg viewBox="0 0 20 20" fill="currentColor"><path d="M9 6a3 3 0 11-6 0 3 3 0 016 0zM17 6a3 3 0 11-6 0 3 3 0 016 0zM12.93 17c.046-.327.07-.66.07-1a6.97 6.97 0 00-1.5-4.33A5 5 0 0119 16v1h-6.07zM6 11a5 5 0 015 5v1H1v-1a5 5 0 015-5z"/></svg>
      Watchlist
    </a>
    <a href="/network" class="nav-item <%= page === 'network' ? 'active' : '' %>">
      <svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M12.316 3.051a1 1 0 01.633 1.265l-4 12a1 1 0 11-1.898-.632l4-12a1 1 0 011.265-.633zM5.707 6.293a1 1 0 010 1.414L3.414 10l2.293 2.293a1 1 0 11-1.414 1.414l-3-3a1 1 0 010-1.414l3-3a1 1 0 011.414 0zm8.586 0a1 1 0 011.414 0l3 3a1 1 0 010 1.414l-3 3a1 1 0 11-1.414-1.414L16.586 10l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
      Network View
    </a>
    <a href="/audit" class="nav-item <%= page === 'audit' ? 'active' : '' %>">
      <svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4z" clip-rule="evenodd"/></svg>
      Audit Logs
    </a>
    <% if (user && user.role === 'admin') { %>
    <a href="/admin" class="nav-item <%= page === 'admin' ? 'active' : '' %>">
      <svg viewBox="0 0 20 20" fill="currentColor"><path d="M13 6a3 3 0 11-6 0 3 3 0 016 0zM18 8a2 2 0 11-4 0 2 2 0 014 0zM14 15a4 4 0 00-8 0v3h8v-3zM6 8a2 2 0 11-4 0 2 2 0 014 0zM16 18v-3a5.972 5.972 0 00-.75-2.906A3.005 3.005 0 0119 15v3h-3zM4.75 12.094A5.973 5.973 0 004 15v3H1v-3a3 3 0 013.75-2.906z"/></svg>
      User Management
    </a>
    <% } %>
    <a href="/settings" class="nav-item <%= page === 'settings' ? 'active' : '' %>">
      <svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M11.49 3.17c-.38-1.56-2.6-1.56-2.98 0a1.532 1.532 0 01-2.286.948c-1.372-.836-2.942.734-2.106 2.106.54.886.061 2.042-.947 2.287-1.561.379-1.561 2.6 0 2.978a1.532 1.532 0 01.947 2.287c-.836 1.372.734 2.942 2.106 2.106a1.532 1.532 0 012.287.947c.379 1.561 2.6 1.561 2.978 0a1.533 1.533 0 012.287-.947c1.372.836 2.942-.734 2.106-2.106a1.533 1.533 0 01.947-2.287c1.561-.379 1.561-2.6 0-2.978a1.532 1.532 0 01-.947-2.287c.836-1.372-.734-2.942-2.106-2.106a1.532 1.532 0 01-2.287-.947zM10 13a3 3 0 100-6 3 3 0 000 6z" clip-rule="evenodd"/></svg>
      Settings
    </a>
  </nav>

  <div class="sidebar-user">
    <div class="user-avatar-sm"><%= user ? user.username.charAt(0).toUpperCase() : '?' %></div>
    <div class="user-info">
      <span class="user-name"><%= user ? (user.display_name || user.username).toUpperCase() : 'UNKNOWN' %></span>
      <span class="user-role"><%= user ? user.role.toUpperCase() : '' %></span>
    </div>
    <form action="/logout" method="POST" class="logout-form">
      <button type="submit" class="logout-btn" title="Sign out">
        <svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M3 3a1 1 0 00-1 1v12a1 1 0 102 0V4a1 1 0 00-1-1zm10.293 9.293a1 1 0 001.414 1.414l3-3a1 1 0 000-1.414l-3-3a1 1 0 10-1.414 1.414L14.586 9H7a1 1 0 100 2h7.586l-1.293 1.293z" clip-rule="evenodd"/></svg>
      </button>
    </form>
  </div>
</aside>

<main class="main-content">
