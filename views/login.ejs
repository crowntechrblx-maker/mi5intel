<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Authentication — MI5 Intel Portal</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="auth-body">
  <div class="auth-container">
    <div class="auth-header">
      <!-- MI5 Triangle Logo (large) -->
      <div class="auth-crown">
        <svg class="auth-mi5-logo" viewBox="0 0 110 96" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <polygon points="55,3 107,93 3,93" stroke="currentColor" stroke-width="2.5" fill="none" stroke-linejoin="round"/>
          <line x1="14" y1="80" x2="96" y2="80" stroke="currentColor" stroke-width="1.5"/>
          <line x1="32" y1="80" x2="32" y2="93" stroke="currentColor" stroke-width="1"/>
          <line x1="78" y1="80" x2="78" y2="93" stroke="currentColor" stroke-width="1"/>
          <text x="55" y="19" text-anchor="middle" font-size="7" fill="currentColor" font-weight="700" font-family="serif">I</text>
          <ellipse cx="55" cy="28" rx="8.5" ry="5.5" stroke="currentColor" stroke-width="1.5" fill="none"/>
          <circle cx="55" cy="28" r="3" fill="currentColor"/>
          <circle cx="55" cy="28" r="1.2" fill="none" stroke="currentColor" stroke-width="0.5"/>
          <text x="55" y="44" text-anchor="middle" font-size="8" fill="currentColor" font-weight="700" font-family="serif" letter-spacing="2">EIIR</text>
          <line x1="55" y1="47" x2="55" y2="56" stroke="currentColor" stroke-width="1.5"/>
          <line x1="50" y1="51" x2="60" y2="51" stroke="currentColor" stroke-width="1.5"/>
          <rect x="43" y="72" width="24" height="6" stroke="currentColor" stroke-width="1.2" fill="none"/>
          <polyline points="43,72 43,63 48,68 52,58 55,65 58,58 62,68 67,63 67,72" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linejoin="round"/>
          <circle cx="43" cy="63" r="1.2" fill="currentColor"/>
          <circle cx="55" cy="65" r="1.2" fill="currentColor"/>
          <circle cx="67" cy="63" r="1.2" fill="currentColor"/>
          <rect x="44" y="58" width="22" height="9" rx="1" stroke="currentColor" stroke-width="1" fill="black" stroke-dasharray="1.5 1"/>
          <text x="55" y="65.5" text-anchor="middle" font-size="7" fill="currentColor" font-weight="700" font-family="serif" letter-spacing="1.5">007</text>
          <text x="25" y="77" text-anchor="middle" font-size="6.5" fill="currentColor" font-weight="700" font-family="serif">U.</text>
          <text x="85" y="77" text-anchor="middle" font-size="6.5" fill="currentColor" font-weight="700" font-family="serif">K.</text>
          <text x="23" y="90" text-anchor="middle" font-size="5.5" fill="currentColor" font-weight="700" font-family="serif">M</text>
          <text x="55" y="90" text-anchor="middle" font-size="5" fill="currentColor" font-weight="700" font-family="serif" letter-spacing="1.2">INTELLIGENCE</text>
          <text x="87" y="90" text-anchor="middle" font-size="5.5" fill="currentColor" font-weight="700" font-family="serif">V</text>
        </svg>
      </div>
      <span class="auth-gov-dept">Military Intelligence Section 5</span>
      <span class="auth-service-name">Intel Portal</span>
      <div style="margin-top:8px">
        <span class="header-phase">RESTRICTED — INTERNAL ONLY</span>
      </div>
    </div>

    <div class="auth-card">
      <h1 class="auth-title">OPERATOR AUTHENTICATION</h1>
      <p class="auth-subtitle">Authorised personnel only. All access is logged and monitored.</p>

      <% if (setupDone) { %>
        <div class="govuk-notification-banner govuk-notification-banner--success" style="margin-bottom:1rem">
          <div class="govuk-notification-banner__header">SUCCESS</div>
          <div class="govuk-notification-banner__content">Administrator account created. You may now sign in.</div>
        </div>
      <% } %>
      <% if (error) { %>
        <div class="govuk-notification-banner govuk-notification-banner--error" style="margin-bottom:1rem">
          <div class="govuk-notification-banner__header">ACCESS DENIED</div>
          <div class="govuk-notification-banner__content"><%= error %></div>
        </div>
      <% } %>

      <form action="/login" method="POST" class="auth-form">
        <input type="hidden" name="next" value="<%= next %>">
        <div class="govuk-form-group">
          <label class="govuk-label" for="username">OPERATOR ID</label>
          <input class="govuk-input" type="text" id="username" name="username" autocomplete="username" autofocus required>
        </div>
        <div class="govuk-form-group">
          <label class="govuk-label" for="password">ACCESS CODE</label>
          <input class="govuk-input" type="password" id="password" name="password" autocomplete="current-password" required>
        </div>
        <button class="govuk-button govuk-button--primary govuk-button--full" type="submit">AUTHENTICATE &rarr;</button>
      </form>
    </div>

    <p class="auth-footer">Unauthorised access is a criminal offence under the Computer Misuse Act 1990.</p>
  </div>
</body>
</html>
