<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Authentication — MI5 Intel Portal</title>
  <link rel="icon" href="/favicon.svg" type="image/png">
  <meta name="robots" content="noindex, nofollow">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html, body {
      height: 100%;
      background: #000;
      color: #fff;
      font-family: 'Courier New', Courier, monospace;
    }

    /* subtle scanline */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background: repeating-linear-gradient(
        0deg,
        transparent,
        transparent 3px,
        rgba(255,255,255,0.012) 3px,
        rgba(255,255,255,0.012) 4px
      );
      pointer-events: none;
      z-index: 9999;
    }

    /* ── outer wrapper ── */
    .page {
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 48px 20px 96px;
    }

    /* ── top identity row: crest + title ── */
    .identity {
      display: flex;
      align-items: center;
      gap: 36px;
      width: 100%;
      max-width: 680px;
      margin-bottom: 52px;
    }

    .crest-img {
      flex-shrink: 0;
      width: 160px;
      height: 160px;
      object-fit: contain;
      /* render white — the PNG is white on transparent/white bg */
      filter: invert(0) brightness(1);
    }

    .title-block {
      display: flex;
      flex-direction: column;
      gap: 4px;
    }
    .title-eyebrow {
      font-size: 10px;
      letter-spacing: 4px;
      color: #555;
      text-transform: uppercase;
    }
    .title-main {
      font-size: clamp(24px, 3.8vw, 36px);
      font-weight: 700;
      letter-spacing: 8px;
      text-transform: uppercase;
      line-height: 1.15;
      color: #fff;
    }
    .title-rule {
      margin-top: 10px;
      width: 100%;
      height: 1px;
      background: #222;
    }

    /* ── login box ── */
    .box {
      width: 100%;
      max-width: 460px;
      background: #040404;
      border: 1px solid #1c1c1c;
      padding: 34px 38px 38px;
    }

    .box.shake {
      animation: shake 0.4s cubic-bezier(.36,.07,.19,.97) both;
    }
    @keyframes shake {
      10%, 90% { transform: translateX(-2px); }
      20%, 80% { transform: translateX(4px); }
      30%, 50%, 70% { transform: translateX(-6px); }
      40%, 60% { transform: translateX(6px); }
    }

    .box-heading {
      font-size: 9px;
      letter-spacing: 4px;
      color: #444;
      text-transform: uppercase;
      padding-bottom: 14px;
      border-bottom: 1px solid #111;
      margin-bottom: 26px;
    }

    /* alerts */
    .alert {
      font-size: 11px;
      letter-spacing: 1px;
      padding: 9px 12px;
      border-left: 2px solid;
      margin-bottom: 20px;
      line-height: 1.5;
    }
    .alert strong {
      display: block;
      font-size: 9px;
      letter-spacing: 3px;
      text-transform: uppercase;
      margin-bottom: 2px;
    }
    .alert--error   { border-color: #7a0000; color: #cc4444; background: rgba(120,0,0,0.06); }
    .alert--success { border-color: #004e2a; color: #2e8b57; background: rgba(0,78,42,0.07); }

    /* fields */
    .field { margin-bottom: 22px; }
    .field label {
      display: block;
      font-size: 9px;
      letter-spacing: 3px;
      color: #555;
      text-transform: uppercase;
      margin-bottom: 9px;
    }
    .field input {
      width: 100%;
      background: transparent;
      border: none;
      border-bottom: 1px solid #2a2a2a;
      color: #fff;
      font-family: 'Courier New', Courier, monospace;
      font-size: 14px;
      letter-spacing: 3px;
      padding: 7px 0;
      outline: none;
      transition: border-color 0.15s;
    }
    .field input:focus  { border-bottom-color: #fff; }
    .field input::placeholder { color: #1e1e1e; }

    /* submit */
    .btn {
      display: block;
      width: 100%;
      margin-top: 6px;
      background: transparent;
      border: 1px solid #333;
      color: #fff;
      font-family: 'Courier New', Courier, monospace;
      font-size: 10px;
      letter-spacing: 5px;
      text-transform: uppercase;
      padding: 13px;
      cursor: pointer;
      transition: background 0.14s, border-color 0.14s, color 0.14s;
    }
    .btn:hover  { background: #fff; border-color: #fff; color: #000; }
    .btn:active { background: #ccc; }

    /* ── pinned footer ── */
    .warning {
      position: fixed;
      bottom: 0; left: 0; right: 0;
      padding: 12px 24px;
      background: #000;
      border-top: 1px solid #0e0e0e;
      font-size: 9.5px;
      color: #2d2d2d;
      letter-spacing: 1.5px;
      text-align: center;
      line-height: 1.7;
    }
  </style>
</head>
<body>

<div class="page">

  <!-- ── Crest + title ── -->
  <div class="identity">
    <img class="crest-img" src="/favicon.svg" alt="MI5 Government Crest">
    <div class="title-block">
      <span class="title-eyebrow">Government Secure Terminal</span>
      <div class="title-main">MI5 Computer<br>Terminal</div>
      <div class="title-rule"></div>
    </div>
  </div>

  <!-- ── Auth box ── -->
  <div class="box <%= error ? 'shake' : '' %>">
    <div class="box-heading">Operator Authentication Required</div>

    <% if (setupDone) { %>
    <div class="alert alert--success">
      <strong>System</strong>
      Administrator account created. You may now authenticate.
    </div>
    <% } %>
    <% if (error) { %>
    <div class="alert alert--error">
      <strong>Access Denied</strong>
      <%= error %>
    </div>
    <% } %>

    <form action="/login" method="POST">
      <input type="hidden" name="next" value="<%= next %>">

      <div class="field">
        <label for="username">Operator ID</label>
        <input type="text" id="username" name="username"
               autocomplete="username" autofocus required placeholder="______">
      </div>

      <div class="field">
        <label for="password">Access Code</label>
        <input type="password" id="password" name="password"
               autocomplete="current-password" required placeholder="______">
      </div>

      <button class="btn" type="submit">Authenticate &rarr;</button>
    </form>
  </div>

</div>

<p class="warning">
  Warning: you are logging into a Government Terminal which may contain information for authorised people only.<br>
  Any unauthorised attempts to gain access to this system may result in legal action being taken.
</p>

</body>
</html>
