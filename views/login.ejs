<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Authentication — MI5 Intelligence Portal</title>
  <link rel="icon" href="/favicon.png" type="image/png">
  <meta name="robots" content="noindex, nofollow">
  <meta name="description" content="MI5 Intelligence Portal — Classified Roblox threat intelligence platform. Authorised personnel only.">

  <!-- Open Graph -->
  <meta property="og:type"         content="website">
  <meta property="og:site_name"    content="MI5 Intelligence Portal">
  <meta property="og:title"        content="MI5 Intelligence Portal">
  <meta property="og:description"  content="Military Intelligence Section 5 — Classified Roblox threat intelligence platform. RESTRICTED — AUTHORISED PERSONNEL ONLY.">
  <meta property="og:url"          content="<%= baseUrl %>">
  <meta property="og:image"        content="<%= baseUrl %>/og-image.png">
  <meta property="og:image:type"   content="image/png">
  <meta property="og:image:width"  content="500">
  <meta property="og:image:height" content="500">

  <!-- Twitter / X -->
  <meta name="twitter:card"        content="summary">
  <meta name="twitter:title"       content="MI5 Intelligence Portal">
  <meta name="twitter:description" content="Military Intelligence Section 5 — Classified Roblox threat intelligence platform.">
  <meta name="twitter:image"       content="<%= baseUrl %>/og-image.png">

  <!-- Discord embed accent colour -->
  <meta name="theme-color" content="#1d70b8">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html, body {
      height: 100%;
      background: #000;
      color: #fff;
      font-family: 'Courier New', Courier, monospace;
    }

    /* scanline overlay */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background: repeating-linear-gradient(
        0deg,
        transparent,
        transparent 3px,
        rgba(255,255,255,0.011) 3px,
        rgba(255,255,255,0.011) 4px
      );
      pointer-events: none;
      z-index: 9999;
    }

    /* ── outer wrapper ── */
    .page {
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 48px 20px 96px;
    }

    /* ── identity row: crest left, title right ── */
    .identity {
      display: flex;
      align-items: center;
      gap: 44px;
      width: 100%;
      max-width: 700px;
      margin-bottom: 56px;
    }

    .crest-img {
      flex-shrink: 0;
      width: 180px;
      height: 180px;
      object-fit: contain;
    }

    .title-block {
      display: flex;
      flex-direction: column;
      gap: 6px;
    }
    .title-eyebrow {
      font-size: 10px;
      letter-spacing: 5px;
      color: #ffffff;
      text-transform: uppercase;
    }
    .title-main {
      font-size: clamp(26px, 4vw, 38px);
      font-weight: 700;
      letter-spacing: 10px;
      text-transform: uppercase;
      line-height: 1.18;
      color: #fff;
    }
    .title-rule {
      margin-top: 12px;
      width: 100%;
      height: 1px;
      background: #1e1e1e;
    }

    /* ── login box ── */
    .box {
      width: 100%;
      max-width: 460px;
      background: #000;
      border: 1px solid #181818;
      padding: 36px 40px 40px;
    }

    .box.shake {
      animation: shake 0.42s cubic-bezier(.36,.07,.19,.97) both;
    }
    @keyframes shake {
      10%, 90% { transform: translateX(-2px); }
      20%, 80% { transform: translateX(4px); }
      30%, 50%, 70% { transform: translateX(-6px); }
      40%, 60% { transform: translateX(6px); }
    }

    .box-heading {
      font-size: 9px;
      letter-spacing: 5px;
      color: #ffffff;
      text-transform: uppercase;
      padding-bottom: 16px;
      border-bottom: 1px solid #111;
      margin-bottom: 28px;
    }

    /* alerts */
    .alert {
      font-size: 11px;
      letter-spacing: 1px;
      padding: 10px 13px;
      border-left: 2px solid;
      margin-bottom: 22px;
      line-height: 1.6;
    }
    .alert strong {
      display: block;
      font-size: 9px;
      letter-spacing: 3px;
      text-transform: uppercase;
      margin-bottom: 3px;
    }
    .alert--error   { border-color: #6e0000; color: #c03333; background: rgba(110,0,0,0.07); }
    .alert--success { border-color: #004422; color: #267a4a; background: rgba(0,68,34,0.08); }

    /* fields */
    .field { margin-bottom: 24px; }
    .field label {
      display: block;
      font-size: 9px;
      letter-spacing: 4px;
      color: #ffffff;
      text-transform: uppercase;
      margin-bottom: 10px;
    }
    .field input {
      width: 100%;
      background: transparent;
      border: none;
      border-bottom: 1px solid #222;
      color: #fff;
      font-family: 'Courier New', Courier, monospace;
      font-size: 14px;
      letter-spacing: 3px;
      padding: 8px 0;
      outline: none;
      transition: border-color 0.15s;
    }
    .field input:focus        { border-bottom-color: #ffffff9f; }
    .field input::placeholder { color: #000000; }

    /* submit */
    .btn {
      display: block;
      width: 100%;
      margin-top: 8px;
      background: transparent;
      border: 1px solid #2c2c2c;
      color: #ffffff;
      font-family: 'Courier New', Courier, monospace;
      font-size: 10px;
      letter-spacing: 6px;
      text-transform: uppercase;
      padding: 14px;
      cursor: pointer;
      transition: background 0.13s, border-color 0.13s, color 0.13s;
    }
    .btn:hover  { background: #fff; border-color: #fff; color: #000; }
    .btn:active { background: #ccc; }

    /* ── pinned warning footer ── */
    .warning {
      position: fixed;
      bottom: 0; left: 0; right: 0;
      padding: 13px 32px;
      background: #000;
      border-top: 1px solid #0d0d0d;
      font-size: 9px;
      color: #ff0000;
      letter-spacing: 1.5px;
      text-align: center;
      line-height: 1.8;
    }
  </style>
</head>
<body>

<div class="page">

  <!-- ── Crest + title ── -->
  <div class="identity">
    <img class="crest-img" src="/loginlogo.png">
    <div class="title-block">
      <span class="title-eyebrow">Government Secure Terminal</span>
      <div class="title-main">MI5 Computer<br>Terminal</div>
      <div class="title-rule"></div>
    </div>
  </div>

  <!-- ── Auth box ── -->
  <div class="box <%= error ? 'shake' : '' %>">
    <div class="box-heading">Operator Authentication Required</div>

    <% if (setupDone) { %>
    <div class="alert alert--success">
      <strong>System</strong>
      Administrator account created. You may now authenticate.
    </div>
    <% } %>
    <% if (error) { %>
    <div class="alert alert--error">
      <strong>Access Denied</strong>
      <%= error %>
    </div>
    <% } %>

    <form action="/login" method="POST">
      <input type="hidden" name="next" value="<%= next %>">

      <div class="field">
        <label for="username">Operator ID</label>
        <input type="text" id="username" name="username"
               autocomplete="username" autofocus required placeholder="______">
      </div>

      <div class="field">
        <label for="password">Access Code</label>
        <input type="password" id="password" name="password"
               autocomplete="current-password" required placeholder="______">
      </div>

      <button class="btn" type="submit">Authenticate &rarr;</button>
    </form>
  </div>

</div>

<!-- ── Warning footer ── -->
<p class="warning">
  Warning: you are logging into a Government Terminal which may contain information for authorised people only.<br>
  Any unauthorised attempts to gain access to this system may result in legal action being taken.
</p>

</body>
</html>
