<%- include('../partials/header', { pageTitle: 'PSD Case Reports', page: 'psd' }) %>

<div class="govuk-page-header">
  <div>
    <span class="govuk-caption-m">PROFESSIONAL STANDARDS DEPARTMENT — RESTRICTED</span>
    <h1 class="govuk-heading-xl">PSD Case Reports</h1>
  </div>
  <a href="/psd/new" class="btn btn-primary btn-sm">+ FILE CASE REPORT</a>
</div>

<div style="background:rgba(212,53,28,.08);border:1px solid rgba(212,53,28,.3);border-left:4px solid var(--red);padding:12px 16px;margin-bottom:1.5rem;border-radius:var(--r)">
  <div style="font-size:9px;letter-spacing:3px;color:#e08080;text-transform:uppercase;font-family:var(--mono);margin-bottom:4px">SECURITY NOTICE</div>
  <div style="font-size:12px;color:#c08080;line-height:1.6">This section is restricted to <strong style="color:#e08080">BAND 5 CLEARANCE</strong> personnel only. Unauthorised access or disclosure constitutes a breach of security and may result in disciplinary proceedings and withdrawal of clearance.</div>
</div>

<div class="panel">
  <div class="panel-header">
    <span class="panel-title">CASE REGISTRY (<%= cases.length %>)</span>
  </div>
  <% if (!cases.length) { %>
  <div class="panel-body"><p class="text-muted">No case reports on file.</p></div>
  <% } else { %>
  <table class="registry-table">
    <thead>
      <tr>
        <th>FILE REF</th>
        <th>ACCUSED OFFICER</th>
        <th>INVESTIGATING OFFICER</th>
        <th>MISCONDUCT LEVEL</th>
        <th>DECISION</th>
        <th>FILED</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% cases.forEach(function(c) { %>
      <tr>
        <td class="mono" style="font-size:11px;font-weight:700;color:var(--blue-light)">
          <a href="/psd/<%= c.reference %>" style="color:var(--blue-light);text-decoration:none"><%= c.reference %></a>
        </td>
        <td class="mono" style="font-weight:600"><%= c.accused_officer %></td>
        <td class="text-muted" style="font-size:12px"><%= c.investigating_officer %></td>
        <td>
          <% const lvlCol = c.misconduct_level === 'SEVERE MISCONDUCT' ? 'red' : c.misconduct_level === 'MISCONDUCT' ? 'orange' : 'grey'; %>
          <span class="govuk-tag govuk-tag--<%= lvlCol %>" style="font-size:9px"><%= c.misconduct_level %></span>
        </td>
        <td style="font-size:11px;max-width:200px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis"><%= c.disciplinary_decision %></td>
        <td class="mono text-muted" style="font-size:10px;white-space:nowrap"><%= new Date(c.created_at).toLocaleDateString('en-GB') %></td>
        <td><a href="/psd/<%= c.reference %>" class="btn btn-ghost btn-xs">VIEW</a></td>
      </tr>
      <% }); %>
    </tbody>
  </table>
  <% } %>
</div>

<%- include('../partials/footer') %>
