<%- include('../partials/header', { pageTitle: report.reference, page: 'psd' }) %>

<div class="govuk-page-header">
  <div>
    <span class="govuk-caption-m">PSD — DISCIPLINARY SUMMARY — RESTRICTED</span>
    <h1 class="govuk-heading-xl"><%= report.reference %></h1>
  </div>
  <div style="display:flex;gap:.5rem">
    <a href="<%= report.doc_url %>" target="_blank" rel="noopener" class="btn btn-primary btn-sm">OPEN IN GOOGLE DOCS &nearr;</a>
    <a href="/psd" class="btn btn-secondary btn-sm">&larr; Back</a>
    <% if (user.role === 'admin') { %>
    <form action="/psd/<%= report.reference %>/delete" method="POST" style="display:inline"
          onsubmit="return confirm('Permanently delete this case log?')">
      <button class="btn btn-danger btn-sm" type="submit">DELETE</button>
    </form>
    <% } %>
  </div>
</div>

<div class="admin-grid" style="grid-template-columns:260px 1fr;align-items:start">

  <!-- Metadata -->
  <div>
    <div class="panel">
      <div class="panel-header"><span class="panel-title">CASE RECORD</span></div>
      <div class="panel-body" style="display:flex;flex-direction:column;gap:.8rem">

        <div>
          <div style="font-size:9px;letter-spacing:3px;color:var(--mid-grey);text-transform:uppercase;margin-bottom:3px">File Reference</div>
          <div class="mono" style="font-size:12px;font-weight:700;color:var(--blue-light)"><%= report.reference %></div>
        </div>

        <div>
          <div style="font-size:9px;letter-spacing:3px;color:var(--mid-grey);text-transform:uppercase;margin-bottom:3px">Accused Officer</div>
          <div class="mono" style="font-size:13px;font-weight:700"><%= report.accused_officer %></div>
        </div>

        <div>
          <div style="font-size:9px;letter-spacing:3px;color:var(--mid-grey);text-transform:uppercase;margin-bottom:3px">Investigating Officer</div>
          <div style="font-size:12px"><%= report.investigating_officer %></div>
        </div>

        <div>
          <div style="font-size:9px;letter-spacing:3px;color:var(--mid-grey);text-transform:uppercase;margin-bottom:4px">Misconduct Level</div>
          <% const lvlCol = report.misconduct_level === 'SEVERE MISCONDUCT' ? 'red' : report.misconduct_level === 'MISCONDUCT' ? 'orange' : 'grey'; %>
          <span class="govuk-tag govuk-tag--<%= lvlCol %>"><%= report.misconduct_level %></span>
        </div>

        <div>
          <div style="font-size:9px;letter-spacing:3px;color:var(--mid-grey);text-transform:uppercase;margin-bottom:3px">Decision</div>
          <div style="font-size:12px;font-weight:600;color:var(--white)"><%= report.disciplinary_decision %></div>
        </div>

        <div>
          <div style="font-size:9px;letter-spacing:3px;color:var(--mid-grey);text-transform:uppercase;margin-bottom:3px">Logged By</div>
          <div class="mono" style="font-size:11px"><%= report.filed_by %></div>
        </div>

        <div>
          <div style="font-size:9px;letter-spacing:3px;color:var(--mid-grey);text-transform:uppercase;margin-bottom:3px">Date Logged</div>
          <div class="mono" style="font-size:11px"><%= new Date(report.created_at).toLocaleDateString('en-GB', { day:'2-digit', month:'long', year:'numeric' }) %></div>
        </div>

        <div style="padding-top:.5rem;border-top:1px solid var(--border)">
          <div style="font-size:8px;letter-spacing:2px;color:var(--dim-grey);text-transform:uppercase;line-height:1.8">RESTRICTED — NEED TO KNOW ONLY<br>PROFESSIONAL STANDARDS DEPARTMENT</div>
        </div>
      </div>
    </div>

    <% if (report.notes) { %>
    <div class="panel">
      <div class="panel-header"><span class="panel-title">INTERNAL NOTES</span></div>
      <div class="panel-body">
        <div style="font-size:12px;line-height:1.7;color:var(--grey);white-space:pre-wrap"><%= report.notes %></div>
      </div>
    </div>
    <% } %>
  </div>

  <!-- Document preview / link -->
  <div>
    <div class="panel">
      <div class="panel-header" style="display:flex;align-items:center;justify-content:space-between">
        <span class="panel-title">DOCUMENT</span>
        <a href="<%= report.doc_url %>" target="_blank" rel="noopener" style="font-size:10px;color:var(--blue-light);text-decoration:none;letter-spacing:1px">OPEN IN NEW TAB &nearr;</a>
      </div>
      <div style="background:#1a1b1c;border-radius:0 0 var(--r) var(--r);overflow:hidden">
        <%
          // Convert Google Docs edit URL to embed/preview URL
          let embedUrl = report.doc_url;
          if (embedUrl.includes('/edit')) {
            embedUrl = embedUrl.replace(/\/edit.*$/, '/preview');
          } else if (embedUrl.includes('/pub')) {
            embedUrl = embedUrl.replace(/\/pub.*$/, '/preview');
          } else if (!embedUrl.includes('/preview')) {
            embedUrl = embedUrl.replace(/\?.*$/, '') + '/preview';
          }
        %>
        <iframe
          src="<%= embedUrl %>"
          width="100%"
          height="700"
          frameborder="0"
          style="display:block;background:#fff"
          allowfullscreen
          title="PSD Case Report Document">
        </iframe>
      </div>
      <div style="padding:8px 16px;font-size:10px;color:var(--dim-grey);border-top:1px solid var(--border)">
        If the document does not load, ensure it is shared as "Anyone with the link can view" in Google Docs.
      </div>
    </div>
  </div>

</div>

<%- include('../partials/footer') %>
